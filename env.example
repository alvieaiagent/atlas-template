# Copy this file to .env.local and fill in your own values.
# 冇任何 env 都可以 `pnpm dev` — app 會用 mock data 起機。

# ── Required: Supabase（Dashboard → Settings → API）──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── App password gate（留空 = 唔鎖，方便 localhost；上 Vercel 記得 set）──
ATLAS_PASSWORD=

# ── Optional: X / Threads / IG scraping ──
APIFY_TOKEN=
SCRAPECREATORS_API_KEY=

# ── Optional: AI 功能（逐字稿 / 自動分類 / 生成）──
GEMINI_API_KEY=

# ── Optional: 保護 /api/cron/*（production radar cron 必須）──
CRON_SECRET=

# ── Optional: iOS 捷徑 share capture（/capture?k=<token>&url=...）──
ATLAS_CAPTURE_TOKEN=

# ── Optional: Facebook link capture ──
FACEBOOK_APIFY_ACTOR=kingscraper/facebook-post-scraper
FACEBOOK_OEMBED_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_CLIENT_TOKEN=
FACEBOOK_GRAPH_VERSION=v25.0
